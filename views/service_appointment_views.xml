<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="service_appointment_view_list" model="ir.ui.view">
            <field name="name">service.appointment.view.list</field>
            <field name="model">service.appointment</field>
            <field name="arch" type="xml">
                <list string="Service Appointments">
                    <field name="name" />
                    <field name="customer_name" />
                    <field name="plat_number" />
                    <field name="vehicle_brand" />
                    <field name="vehicle_model" />
                    <field name="plan_service_date" />
                    <field name="service_type" />
                    <field name="state" widget="badge" decoration-info="state == 'draft'"
                        decoration-warning="state == 'in_progress'"
                        decoration-success="state == 'done'"
                        decoration-danger="state == 'cancelled'" />
                    <field name="job_order_id" optional="hide" />
                </list>
            </field>
        </record>

        <record id="service_appointment_view_form" model="ir.ui.view">
            <field name="name">service.appointment.view.form</field>
            <field name="model">service.appointment</field>
            <field name="arch" type="xml">
                <form string="Service Appointment">
                    <header>
                        <button name="action_mark_in_progress"
                            string="Start"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"
                            confirm="Are you sure you want to mark this appointment as 'In Progress' and create a Job Order?" />
                        <button name="action_mark_done"
                            string="Mark as Done"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'in_progress'"
                            confirm="Are you sure you want to mark this appointment as 'Done'?" />
                        <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            invisible="state not in ('draft', 'in_progress')"
                            confirm="Are you sure you want to cancel this appointment?" />
                        <field name="state" widget="statusbar"
                            statusbar_visible="draft,in_progress,done" />
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_job_order"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-wrench"
                                invisible="job_order_count == 0">
                                <field name="job_order_count" widget="statinfo" string="Job Order" />
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1" />
                            </h1>
                        </div>
                        <group>
                            <group string="Customer &amp; Contact Information">
                                <field name="customer_name" />
                                <field name="contact_number" />
                                <field name="contact_email" />
                                <field name="create_date" string="Appointment Created On"
                                    readonly="1" />
                            </group>
                            <group string="Vehicle Information">
                                <field name="plat_number" />
                                <field name="vehicle_brand" />
                                <field name="vehicle_model" />
                                <field name="vehicle_year_manufacture" options="{'format': false}" />
                                <field name="kilometers" />
                            </group>
                        </group>
                        <notebook>
                            <page string="Appointment Details">
                                <group>
                                    <field name="plan_service_date" />
                                    <field name="service_type" />
                                    <field name="complaint_issue" />
                                    <field name="media_document" widget="many2many_binary"
                                        readonly="1" />
                                </group>
                            </page>
                            <page string="Notes &amp; Cancellation">
                                <group>
                                    <field name="cancel_reason" invisible="state != 'cancelled'" />
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="service_appointment_view_search" model="ir.ui.view">
            <field name="name">service.appointment.view.search</field>
            <field name="model">service.appointment</field>
            <field name="arch" type="xml">
                <search string="Service Appointments">
                    <field name="name" />
                    <field name="customer_name" />
                    <field name="plat_number" />
                    <field name="state" />
                    <filter string="Draft" name="filter_draft" domain="[('state', '=', 'draft')]" />
                    <filter string="Done" name="filter_done" domain="[('state', '=', 'done')]" />
                    <filter string="Cancelled" name="filter_cancelled"
                        domain="[('state', '=', 'cancelled')]" />
                    <group expand="0" string="Group By">
                        <filter name="group_by_state" string="Status"
                            context="{'group_by': 'state'}" />
                        <filter name="group_by_customer" string="Customer"
                            context="{'group_by': 'customer_name'}" />
                    </group>
                </search>
            </field>
        </record>

        <record id="service_appointment_action" model="ir.actions.act_window">
            <field name="name">Appointments</field>
            <field name="res_model">service.appointment</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new service appointment
                </p>
                <p>
                    This is where you manage incoming service requests from the website,
                    which can then be converted into Job Orders (Service Bookings).
                </p>
            </field>
        </record>

    </data>
</odoo>