<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="cancel_reason_wizard_form_view" model="ir.ui.view">
            <field name="name">cancel.reason.wizard.form</field>
            <field name="model">cancel.reason.wizard</field>
            <field name="arch" type="xml">
                <form string="Cancellation Reason">
                    <sheet>
                        <group>
                            <field name="cancel_reason" />
                        </group>
                        <footer>
                            <button name="action_confirm_cancel" string="Confirm Cancellation" type="object" class="btn-primary"/>
                            <button string="Cancel" class="btn-secondary" special="cancel"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_cancel_reason_wizard" model="ir.actions.act_window">
            <field name="name">Cancellation Reason</field>
            <field name="res_model">cancel.reason.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="model_service_appointment"/>
            <field name="binding_model_id" ref="model_service_booking"/>
        </record>
    </data>
</odoo>